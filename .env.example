NODE_ENV=development        # development | production
PORT=3000                   # HTTP port the app listens on

# ── PostgreSQL ────────────────────────────────────────────────
# Dev: local PostgreSQL | Prod: Supabase PostgreSQL (same keys, different values)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=                # your DB password
DB_NAME=medstore_dev        # database name

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=          # min 32 random characters
JWT_REFRESH_SECRET=         # min 32 random characters (different from access)

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=               # https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=       # service_role key (not anon key)

# ── Google OAuth 2.0 ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                  # Gmail address
SMTP_PASS=                  # Gmail app password (not your account password)

# ── Frontend URLs ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001   # customer-facing storefront
DASHBOARD_URL=http://localhost:3002  # admin/staff dashboard
